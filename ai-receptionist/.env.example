# Local dev: keep Ollama (matches config.json ai_provider). VPS uses dashboard ai.provider=anthropic.
AI_PROVIDER=ollama

# Ollama Cloud — https://ollama.com/settings/keys
OLLAMA_API_KEY=

# Optional: default https://ollama.com/api/chat
# OLLAMA_API_URL=https://ollama.com/api/chat

# OpenAI (when AI_PROVIDER=openai or dashboard provider=openai)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://sg.api.openai.com
# OPENAI_MODEL=gpt-4.1-mini

# Optional latency budgets (seconds)
# PLANNER_TIMEOUT_SEC=6
# PLANNER_REPAIR_TIMEOUT_SEC=4
# TOOLS_TIMEOUT_SEC=10
# COLLATE_TIMEOUT_SEC=20
# FAST_COMPLETE_TIMEOUT_SEC=20
# OVERALL_AI_TIMEOUT_SEC=30
# ACK_DELAY_SEC=3
# (default ack delay is 2.5s if unset)
# ACK_COOLDOWN_SEC=300
# AGENT_STATE_MAX_AGE_SEC=3600

# Optional overrides
# WHATSMEOW_DB=whatsmeow.db
# APP_DB=database.db
# HTTP_ADDR=127.0.0.1:8080
# Admin dashboard/API auth (recommended when exposed beyond localhost)
# Option A: token auth via `Authorization: Bearer ...` or `X-Admin-Token: ...`
# DASHBOARD_AUTH_TOKEN=
# Option B: basic auth
# DASHBOARD_BASIC_USER=
# DASHBOARD_BASIC_PASS=
# GRAPHITI_URL=http://127.0.0.1:8333
# MEMORY_RECALL_IN_PROMPT=1
# PocketBase agent persistence (see pocketbase/README.md)
# VPS (stable): POCKETBASE_URL=http://127.0.0.1:8090
# Public admin UI: https://pocketbase-mqk9.srv943071.hstgr.cloud
# POCKETBASE_URL=http://127.0.0.1:8090
# POCKETBASE_TOKEN=
# POCKETBASE_ADMIN_EMAIL=
# POCKETBASE_ADMIN_PASSWORD=
# ECHO_INTENT=1
# Model routing (see internal/models/router.go). Overrides GetModel(taskType).
# INTENT_CLASSIFY_MODEL=          # e.g. gemma4:31b-cloud (Ollama) or claude-haiku-4-5-20251001 (Anthropic)
# PLANNER_MODEL=
# COLLATE_MODEL=
# Google Calendar (service account JSON path)
# GOOGLE_CALENDAR_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CALENDAR_ID=primary
# CALENDAR_TZ=Asia/Singapore
# OWNER_EMAIL=owner@example.com
# DASHBOARD_DIST=dashboard/dist
# CONFIG_PATH=config.json
# PROMPT_PATH=prompt.txt
# PROMPT_LAYOUT=stacked  # default: bundled (SOUL in system, KNOWLEDGE+history in user turn)
# STYLE_EXAMPLES_PATH=style-examples.txt
# ERROR_LOG_PATH=errors.log
